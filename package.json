{
  "name": "pptez",
  "private": true,
  "version": "0.0.0",
  "description": "PPTEZ — a Bun + React + Vite timeline-based presentation editor with keyframe animation and SQLite persistence.",
  "type": "module",
  "author": "eunhhu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/eunhhu/pptez.git"
  },
  "bugs": {
    "url": "https://github.com/eunhhu/pptez/issues"
  },
  "homepage": "https://github.com/eunhhu/pptez#readme",
  "keywords": [
    "presentation",
    "slides",
    "animation",
    "keyframe",
    "timeline",
    "react",
    "vite",
    "framer-motion",
    "bun"
  ],
  "scripts": {
    "dev": "bun --bun vite",
    "build": "tsc -b && bun --bun vite build",
    "typecheck": "tsc -b --force",
    "lint": "eslint .",
    "preview": "bun --bun vite preview"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/babel__core": "^7.20.5",
    "@types/bun": "^1.3.11",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  }
}
